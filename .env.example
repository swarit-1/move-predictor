# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/move_predictor
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/move_predictor

# Redis
REDIS_URL=redis://localhost:6379

# ML Service
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_HOST=0.0.0.0
ML_SERVICE_PORT=8000

# Node.js Backend
BACKEND_PORT=3000
NODE_ENV=development

# Stockfish
STOCKFISH_PATH=/usr/local/bin/stockfish
STOCKFISH_DEPTH=18
STOCKFISH_THREADS=1
STOCKFISH_POOL_SIZE=4

# Lichess API
LICHESS_API_TOKEN=

# Training
DEVICE=cpu
BATCH_SIZE=1024
LEARNING_RATE=0.001
NUM_EPOCHS=20
CHECKPOINT_DIR=data/checkpoints
LOG_DIR=runs

# Frontend
VITE_API_URL=http://localhost:3000/api
